{
  "name": "zero",
  "version": "0.1.0",
  "private": true,
  "description": "Distraction impulse-vs-action tracker",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:api": "pnpm --filter @zero/api dev",
    "dev:web": "pnpm --filter @zero/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @zero/api db:migrate",
    "db:generate": "pnpm --filter @zero/api db:generate",
    "db:seed": "pnpm --filter @zero/api db:seed"
  }
}
