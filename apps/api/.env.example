# Postgres connection string (Neon or local). Example local:
#   postgres://postgres:postgres@localhost:5432/zero
DATABASE_URL=

# Secret used to sign dashboard session tokens (JWT). Use a long random string.
SESSION_SECRET=dev-insecure-secret-change-me

# Port the API listens on.
PORT=4000

# Allowed browser origin for CORS (the web app). "*" for local dev.
WEB_ORIGIN=*

# Used by `pnpm db:seed` to bootstrap the first account + device.
SEED_EMAIL=you@example.com
SEED_PASSWORD=changeme
SEED_TZ=America/New_York
SEED_DEVICE_NAME=desk buttons
# Set to 1 to also generate ~3 weeks of sample presses for the dashboard.
SEED_SAMPLE=0
